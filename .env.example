# --- Postgres ---
# Required — compose will refuse to start if any of these are unset.
# Choose your own values; do NOT ship a default/shared password.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Backend ---
# When running fully in docker-compose, the API talks to the `db` service host.
# Must match the POSTGRES_* values above.
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# For running the API on the host (outside docker) point at localhost:5433
# (the db container is published on host port 5433 to avoid clashing with a local Postgres):
# DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB}
# Required — generate a strong random value, e.g. `openssl rand -hex 32`.
# The app will refuse to start if this is unset.
JWT_SECRET=
JWT_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:5173
# Wipe & reseed synthetic data on container start (dev convenience).
SEED_ON_START=true
# Structured logging. LOG_LEVEL is any standard level name
# (DEBUG/INFO/WARNING/ERROR/CRITICAL). Logs are written as JSON to stdout for the
# Docker log driver; set LOG_JSON=false for the human-readable console renderer.
LOG_LEVEL=INFO
LOG_JSON=true

# --- Database backups (prod only — used by the db-backup service) ---
# Cron schedule for pg_dump. Accepts @daily/@weekly/@hourly or a 6-field cron
# expression (sec min hour dom mon dow). Daily at 02:00 by default.
BACKUP_SCHEDULE=@daily
# Rolling retention: how many daily / weekly / monthly dumps to keep.
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# --- Frontend ---
VITE_API_URL=http://localhost:8000
# Optional: enables a real map on camp/organisation locations. Left blank the UI
# falls back to a static address card — no Maps integration is wired yet.
# VITE_GOOGLE_MAPS_API_KEY=

# --- Postgres ---
POSTGRES_USER=bloodbank
POSTGRES_PASSWORD=bloodbank
POSTGRES_DB=bloodbank

# --- Backend ---
# When running fully in docker-compose, the API talks to the `db` service host.
DATABASE_URL=postgresql+psycopg://bloodbank:bloodbank@db:5432/bloodbank
# For running the API on the host (outside docker) point at localhost:5433
# (the db container is published on host port 5433 to avoid clashing with a local Postgres):
# DATABASE_URL=postgresql+psycopg://bloodbank:bloodbank@localhost:5433/bloodbank
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:5173
# Wipe & reseed synthetic data on container start (dev convenience).
SEED_ON_START=true

# --- Frontend ---
VITE_API_URL=http://localhost:8000
# Optional: enables a real map on camp/organisation locations. Left blank the UI
# falls back to a static address card — no Maps integration is wired yet.
# VITE_GOOGLE_MAPS_API_KEY=
